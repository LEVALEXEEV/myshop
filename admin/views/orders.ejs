<%- include('partials/_head', { title: 'Заказы' }) %>
<%- include('partials/_nav', { csrfToken, active: 'orders' }) %>

<div class="page">
  <div class="page-header">
    <div>
      <div class="page-header__title">Заказы</div>
      <div class="page-header__sub">Всего: <%= summary.total %></div>
    </div>
    <form method="post" action="/orders/export-to-sheets" style="margin:0">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn btn-neutral btn-sm" type="submit">↑ Выгрузить в Google Sheets</button>
    </form>
  </div>

  <% if (query.exportUrl) { %>
    <div class="alert alert-success" style="margin-bottom:16px">
      Выгрузка завершена. <a href="<%= query.exportUrl %>" target="_blank" rel="noopener">Открыть таблицу →</a>
    </div>
  <% } %>
  <% if (query.exportError === 'no_promos') { %>
    <div class="alert alert-danger" style="margin-bottom:16px">
      Нет промокодов с включённой выгрузкой. Включи флаг «Выгрузка» в разделе <a href="/promos">Промокоды</a>.
    </div>
  <% } %>
  <% if (query.exportError === 'fail') { %>
    <div class="alert alert-danger" style="margin-bottom:16px">
      Ошибка выгрузки в Google Sheets. Проверь настройки GOOGLE_SA_KEY_PATH / GOOGLE_SHEETS_ID в .env.
    </div>
  <% } %>

  <!-- Фильтры -->
  <div class="card" style="margin-bottom:20px">
    <div class="card__body" style="padding:14px 20px">
      <form method="get" action="/orders" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <select class="form-control" name="status" style="max-width:180px">
          <option value="">Все статусы</option>
          <% for (const s of statuses) { %>
            <option value="<%= s %>" <%= statusFilter === s ? 'selected' : '' %>><%= statusLabels[s] %></option>
          <% } %>
        </select>
        <select class="form-control" name="promo" style="max-width:200px">
          <option value="">Все промокоды</option>
          <% for (const p of promos) { %>
            <option value="<%= p %>" <%= promoFilter === p ? 'selected' : '' %>><%= p %></option>
          <% } %>
        </select>
        <button class="btn btn-primary btn-sm" type="submit">Применить</button>
        <% if (statusFilter || promoFilter) { %>
          <a href="/orders" class="btn btn-neutral btn-sm">Сбросить</a>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Саммари -->
  <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:20px">
    <div class="card" style="flex:1;min-width:140px">
      <div class="card__body" style="padding:14px 20px">
        <div class="muted" style="font-size:12px;margin-bottom:4px">Заказов</div>
        <div style="font-size:22px;font-weight:700"><%= summary.total %></div>
      </div>
    </div>
    <div class="card" style="flex:1;min-width:140px">
      <div class="card__body" style="padding:14px 20px">
        <div class="muted" style="font-size:12px;margin-bottom:4px">Сумма</div>
        <div style="font-size:22px;font-weight:700"><%= summary.totalSum.toLocaleString('ru-RU') %> ₽</div>
      </div>
    </div>
    <% for (const s of statuses) { %>
      <% if (summary.byStatus[s]) { %>
      <div class="card" style="flex:1;min-width:140px">
        <div class="card__body" style="padding:14px 20px">
          <div class="muted" style="font-size:12px;margin-bottom:4px"><%= statusLabels[s] %></div>
          <div style="font-size:22px;font-weight:700"><%= summary.byStatus[s].count %></div>
          <div class="muted" style="font-size:13px;margin-top:2px"><%= summary.byStatus[s].sum.toLocaleString('ru-RU') %> ₽</div>
        </div>
      </div>
      <% } %>
    <% } %>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Дата</th>
            <th>Покупатель</th>
            <th>Телефон</th>
            <th>Доставка</th>
            <th>Промокод</th>
            <th>Сумма, ₽</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% for (const o of orders) {
               const date = new Date(o.created_at).toLocaleString('ru-RU', {
                 day: '2-digit', month: '2-digit', year: '2-digit',
                 hour: '2-digit', minute: '2-digit',
               });
          %>
            <tr>
              <td class="muted" style="font-size:12px">#<%= o.id %></td>
              <td class="muted" style="white-space:nowrap;font-size:12px"><%= date %></td>
              <td>
                <div style="font-weight:500"><%= o.full_name %></div>
                <div class="muted" style="font-size:12px"><%= o.email %></div>
              </td>
              <td style="white-space:nowrap"><%= o.phone %></td>
              <td>
                <% if (o.shipping_method === 'delivery') { %>
                  <span class="badge badge-yellow">Доставка</span>
                <% } else { %>
                  <span class="badge badge-gray">Самовывоз</span>
                <% } %>
              </td>
              <td>
                <% if (o.promo) { %><code><%= o.promo %></code><% } else { %><span class="muted">—</span><% } %>
              </td>
              <td style="font-weight:600"><%= o.total.toLocaleString('ru-RU') %></td>
              <td>
                <% if (o.status === 'paid') { %>
                  <span class="badge badge-green">Оплачен</span>
                <% } else if (o.status === 'completed') { %>
                  <span class="badge badge-blue">Доставлен</span>
                <% } else if (o.status === 'cancelled') { %>
                  <span class="badge badge-red">Отменён</span>
                <% } else { %>
                  <span class="badge badge-yellow">Ожидает</span>
                <% } %>
              </td>
              <td>
                <a href="/orders/<%= o.id %>" class="btn btn-ghost btn-sm">Подробнее</a>
              </td>
            </tr>
          <% } %>
          <% if (!orders.length) { %>
            <tr><td colspan="9" style="text-align:center;padding:32px" class="muted">Заказов не найдено</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>


  </div>
</div>
</body>
</html>
